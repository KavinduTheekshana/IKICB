# PHP Configuration for Large Video Uploads
# This file should be placed in the Laravel root directory
php_value upload_max_filesize 11000M
php_value post_max_size 11000M
php_value max_execution_time 3600
php_value max_input_time 3600
php_value memory_limit 1024M
php_value max_input_vars 10000

# Increase request body limit
LimitRequestBody 11811160064
